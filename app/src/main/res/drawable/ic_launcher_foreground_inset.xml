<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: the Blaze glyph inset inside the 108dp canvas so it
     sits within the safe zone instead of running to the tile edges. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:drawable="@mipmap/ic_launcher_fg_blaze"
        android:left="12dp"
        android:top="12dp"
        android:right="12dp"
        android:bottom="12dp" />
</layer-list>
