<?xml version="1.0" encoding="utf-8"?>
<!-- Window background for the cold-start splash: pure black with the Blazify
     glyph centred, so the very first frame is already branded instead of blank.
     The animated Compose splash takes over from here. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@android:color/black" />
    <item
        android:width="96dp"
        android:height="96dp"
        android:drawable="@drawable/blaze_logo"
        android:gravity="center" />
</layer-list>
